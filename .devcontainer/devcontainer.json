{
    "name": "dbt project",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {
            "version": "latest"
        },
        "ghcr.io/prulloac/devcontainer-features/commitizen:1": {},
        "ghcr.io/devcontainers-extra/features/lefthook-asdf:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "innoverio.vscode-dbt-power-user",
                "ms-azuretools.vscode-docker",
                "dorzey.vscode-sqlfluff",
                "streetsidesoftware.code-spell-checker",
                "eamodio.gitlens",
                "wholroyd.jinja",
                "vivaxy.vscode-conventional-commits",
                "ms-python.python",
                "bastienboutonnet.vscode-dbt",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "files.associations": {
                    "*.sql": "jinja-sql",
                    "*.yml": "jinja-yaml"
                },
                "terminal.integrated.defaultProfile.linux": "bash",
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "editor.formatOnSave": true,
                "dbt.enableNewLineagePanel": true,
                "dbt.powerUser.sqlDialect": "ansi",
                "dbt.powerUser.enableSyntaxCheck": true,
                "dbt.powerUser.enableHover": true,
                "python-envs.alwaysUseUv": true
                // "dbt.powerUser.projectDir": "/workspaces/${localWorkspaceFolderBasename}/src/02_transform/dbt_core"
            }
        }
    },
    "runArgs": [
        "--env-file",
        ".env"
    ],
    "containerEnv": {
        "DBT_PROJECT_DIR": "/workspaces/project/dbt_transformation",
        "DBT_PROFILES_DIR": "/workspaces/project/dbt_transformation/.dbt"
    },
    "postCreateCommand": "if [ ! -f .env ]; then cp .env.example .env; fi && git config --global core.autocrlf input && git config --global core.fileMode false && pre-commit install && pre-commit install --hook-type commit-msg --hook-type pre-push",
    "postStartCommand": "sh -c \"git config core.editor 'code --wait --reuse-window' && git config credential.useHttpPath true && git config pull.rebase true\"",
    "remoteUser": "root"
}
